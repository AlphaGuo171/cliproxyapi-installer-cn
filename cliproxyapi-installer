#!/bin/bash

# CLIProxyAPI Linux Installer (Fixed Version: 6.8.51)
# Linux-specific script that installs, upgrades, and manages CLIProxyAPI
# Downloads, installs, and upgrades CLIProxyAPI while preserving configuration

set -euo pipefail

# --- 核心修改：固定版本与代理配置 ---
FIXED_VERSION="6.8.51"
PROXY_PREFIX="https://gh-proxy.org/"
# 构造基础下载仓库路径
BASE_REPO_URL="https://github.com/router-for-me/CLIProxyAPI/releases/download/v${FIXED_VERSION}"
# ----------------------------------

# Configuration
INSTALL_DIR="$HOME/cliproxyapi"
SCRIPT_NAME="cliproxyapi-installer"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Logging functions
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_step() { echo -e "${CYAN}[STEP]${NC} $1"; }

# Display authentication information for first-time setup
show_authentication_info() {
    echo
    echo -e "${YELLOW}🔐 IMPORTANT: Authentication Setup Required${NC}"
    echo
    echo -e "${BLUE}CLIProxyAPI supports authentication for multiple providers:${NC}"
    echo
    echo -e "${GREEN}📚 Full Documentation:${NC} https://github.com/router-for-me/CLIProxyAPI"
    echo
    echo -e "${YELLOW}Authentication Commands:${NC}"
    echo
    echo -e "${GREEN}Gemini (Google):${NC}    ./cli-proxy-api --login"
    echo -e "${GREEN}OpenAI (Codex):${NC}    ./cli-proxy-api --codex-login"
    echo -e "${GREEN}Claude (Anthropic):${NC} ./cli-proxy-api --claude-login"
    echo -e "${GREEN}Qwen (Alibaba):${NC}     ./cli-proxy-api --qwen-login"
    echo
    echo -e "${YELLOW}💡 Tip: Add --no-browser to any login command to print URL.${NC}"
    echo
}

# Generate OpenAI-format API key
generate_api_key() {
    local prefix="sk-"
    local chars="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local key=""
    for i in {1..45}; do
        key="${key}${chars:$((RANDOM % ${#chars})):1}"
    done
    echo "${prefix}${key}"
}

# Manage documentation intelligently
manage_documentation() {
    echo "Documentation Management"
    echo "========================"
    if ! is_installed; then
        log_error "CLIProxyAPI is not installed."
        exit 1
    fi
    local version_dir=$(get_current_version_dir)
    local readme_file="${version_dir}/README.md"
    local install_readme="${INSTALL_DIR}/README.md"
    echo "📚 Documentation Status:"
    [[ -f "$readme_file" ]] && echo "✅ Project README: Found" || echo "❌ Project README: Missing"
    [[ -f "$install_readme" ]] && echo "✅ Installer README: Found" || echo "❌ Installer README: Missing"
}

# Check if API keys are configured
check_api_keys() {
    local config_file="${INSTALL_DIR}/config.yaml"
    [[ ! -f "$config_file" ]] && return 1
    if grep -q '"your-api-key-1"' "$config_file"; then return 1; fi
    if grep -A 10 "^api-keys:" "$config_file" | grep -v "^#" | grep -q '"sk-[^"]*"'; then return 0; fi
    return 1
}

# Show API key setup guidance
show_api_key_setup() {
    echo -e "${YELLOW}🔑 IMPORTANT: API Keys Required${NC}"
    echo -e "${GREEN}1. Edit:${NC} nano ${INSTALL_DIR}/config.yaml"
    echo -e "${GREEN}2. Replace placeholder keys with your real keys.${NC}"
}

# Show quick start guide
show_quick_start() {
    local install_dir="$1"
    echo -e "${GREEN}🚀 Quick Start Guide:${NC}"
    echo -e "   cd $install_dir"
    if ! check_api_keys; then show_api_key_setup; fi
    echo -e "   ./cli-proxy-api --login"
    echo -e "   ./cli-proxy-api"
}

# Detect Linux architecture
detect_linux_arch() {
    case "$(uname -m)" in
        x86_64|amd64) echo "linux_amd64" ;;
        arm64|aarch64) echo "linux_arm64" ;;
        *)
            log_error "Unsupported architecture: $(uname -m)"
            exit 1
            ;;
    esac
}

# Check if required tools are available
check_dependencies() {
    local missing_tools=()
    if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then missing_tools+=("curl or wget"); fi
    if ! command -v tar >/dev/null 2>&1; then missing_tools+=("tar"); fi
    if [[ ${#missing_tools[@]} -gt 0 ]]; then
        log_error "Missing required tools: ${missing_tools[*]}"; exit 1
    fi
}

# --- 修改后的下载逻辑：直接构造 URL ---
get_release_data() {
    local os_arch="$1"
    local filename="CLIProxyAPI_${FIXED_VERSION}_${os_arch}.tar.gz"
    # 构造完整链接：前缀 + 仓库地址 + 路径 + 文件名
    local download_url="${PROXY_PREFIX}${BASE_REPO_URL}/${filename}"
    echo "${FIXED_VERSION}|${download_url}"
}

# Check status
is_installed() { [[ -f "${INSTALL_DIR}/version.txt" ]]; }
get_current_version() { is_installed && cat "${INSTALL_DIR}/version.txt" 2>/dev/null || echo "none"; }
get_current_version_dir() { 
    local ver=$(get_current_version)
    [[ "$ver" != "none" ]] && echo "${INSTALL_DIR}/${ver}" || echo ""
}

# Backup and restore
backup_config() {
    local config="${INSTALL_DIR}/config.yaml"
    if [[ -f "$config" ]]; then
        local backup_dir="${INSTALL_DIR}/config_backup"
        mkdir -p "$backup_dir"
        local bkp="${backup_dir}/config_$(date +%Y%m%d_%H%M%S).yaml"
        cp "$config" "$bkp"
        log_info "Configuration backed up to: $bkp"
        echo "$bkp"
    else
        echo ""
    fi
}

# Service management
is_service_running() { systemctl --user is-active --quiet cliproxyapi.service 2>/dev/null; }
is_cliproxyapi_running() { pgrep -f "cli-proxy-api" >/dev/null 2>&1; }

stop_cliproxyapi_processes() {
    local pids=$(pgrep -f "cli-proxy-api" 2>/dev/null || true)
    if [[ -n "$pids" ]]; then
        log_info "Stopping processes..."
        echo "$pids" | xargs kill 2>/dev/null || true
        sleep 2
        pgrep -f "cli-proxy-api" | xargs kill -9 2>/dev/null || true
    fi
}

create_systemd_service() {
    local install_dir="$1"
    local systemd_dir="$HOME/.config/systemd/user"
    mkdir -p "$systemd_dir"
    cat > "${systemd_dir}/cliproxyapi.service" << EOF
[Unit]
Description=CLIProxyAPI Service
After=network.target

[Service]
Type=simple
WorkingDirectory=$install_dir
ExecStart=$install_dir/cli-proxy-api
Restart=always
RestartSec=10
Environment=HOME=$HOME

[Install]
WantedBy=default.target
EOF
    systemctl --user daemon-reload 2>/dev/null || true
    log_success "Systemd service installed."
}

setup_config() {
    local version_dir="$1"
    local backup_file="$2"
    local config="${INSTALL_DIR}/config.yaml"
    
    cp "${version_dir}/cli-proxy-api" "${INSTALL_DIR}/cli-proxy-api" 2>/dev/null || true
    
    if [[ -n "$backup_file" && -f "$backup_file" ]]; then
        cp "$backup_file" "$config"
        log_success "Restored existing configuration."
    elif [[ ! -f "$config" ]]; then
        if [[ -f "${version_dir}/config.example.yaml" ]]; then
            cp "${version_dir}/config.example.yaml" "$config"
            local k1=$(generate_api_key)
            local k2=$(generate_api_key)
            sed -i "s/\"your-api-key-1\"/\"$k1\"/g" "$config"
            sed -i "s/\"your-api-key-2\"/\"$k2\"/g" "$config"
            log_success "Created config.yaml with new keys."
        fi
    fi
}

# Main installation function
install_cliproxyapi() {
    local current_version=$(get_current_version)
    local is_upgrade=false
    local service_was_running=$(is_service_running && echo true || echo false)
    
    [[ "$current_version" != "none" ]] && is_upgrade=true
    
    check_dependencies
    local os_arch=$(detect_linux_arch)
    local release_data=$(get_release_data "$os_arch")
    local version=$(echo "$release_data" | cut -d'|' -f1)
    local download_url=$(echo "$release_data" | cut -d'|' -f2)
    
    log_step "Platform: $os_arch"
    log_step "Version: $version"
    log_info "Final URL: $download_url"

    if [[ "$current_version" == "$version" ]]; then
        log_success "CLIProxyAPI is already up to date ($version)"
        return
    fi
    
    if [[ "$is_upgrade" == true ]]; then
        is_service_running && systemctl --user stop cliproxyapi.service
        stop_cliproxyapi_processes
    fi
    
    local backup_file=$(backup_config)
    local version_dir="${INSTALL_DIR}/${version}"
    mkdir -p "$version_dir"
    
    local temp_file=$(mktemp)
    log_info "Downloading package..."
    if command -v curl >/dev/null 2>&1; then
        curl -L -o "$temp_file" "$download_url"
    else
        wget -O "$temp_file" "$download_url"
    fi
    
    tar -xzf "$temp_file" -C "$version_dir"
    rm -f "$temp_file"
    
    chmod +x "${version_dir}/cli-proxy-api" 2>/dev/null || true
    setup_config "$version_dir" "$backup_file"
    chmod +x "${INSTALL_DIR}/cli-proxy-api" 2>/dev/null || true
    
    create_systemd_service "$INSTALL_DIR"
    echo "$version" > "${INSTALL_DIR}/version.txt"
    
    [[ "$service_was_running" == "true" ]] && systemctl --user start cliproxyapi.service
    
    log_success "CLIProxyAPI $version Installation Complete!"
    show_quick_start "$INSTALL_DIR"
}

# Main script logic
main() {
    case "${1:-install}" in
        "install"|"upgrade") install_cliproxyapi ;;
        "status") 
            echo "Directory: $INSTALL_DIR"
            echo "Version: $(get_current_version)"
            is_service_running && echo "Service: Running" || echo "Service: Stopped"
            ;;
        "uninstall")
            read -p "Are you sure? (y/N): " -r
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                rm -rf "$INSTALL_DIR"
                log_success "Uninstalled."
            fi
            ;;
        *)
            echo "Usage: $0 {install|status|uninstall|auth}"
            exit 1
            ;;
    esac
}

main "$@"
